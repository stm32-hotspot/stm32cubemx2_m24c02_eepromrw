        path: $ProjectDir()$/generated/utilities
  build-types:
    - type: debug_GCC
      compiler: GCC
    - type: release_GCC
      compiler: GCC
    - type: debug_IAR
      compiler: IAR
    - type: release_IAR
      compiler: IAR
    - type: debug_AC6
      compiler: AC6
    - type: release_AC6
      compiler: AC6
  projects:
    - project: project/c562re_eeprma2_m24c02_eepromrw.cproject.yml
  packs:
    - pack: STMicroelectronics::basic_stdio@2.0.0
    - pack: STMicroelectronics::button_hw-part@2.0.0
    - pack: STMicroelectronics::CMSIS@6.3.0
